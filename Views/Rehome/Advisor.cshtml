@{
    var id = ViewData["AdvisorId"]?.ToString() ?? "sophie-martin";

    string advName, advInitials, advRole, advLocation, advStat, advAvatarCss, advBio, advEmail, advPhone;
    string[] advTags;

    switch (id) {
        case "marc-tremblay":
            advName = "Marc Tremblay"; advInitials = "MT";
            advRole = "Cat Behaviour Expert"; advLocation = "Toronto, ON"; advStat = "98";
            advAvatarCss = "background:linear-gradient(135deg,#2d7dd2,#1a5fa8)";
            advBio = "With over 15 years working exclusively with cats, Marc brings deep expertise in feline psychology and behaviour modification. He specialises in helping owners navigate multi-cat households, caring for senior cats, and supporting shy or anxious breeds that require extra patience.\n\nMarc takes a calm, evidence-based approach, helping you understand your cat's perspective and find adopters who are truly the right fit for their unique personality.";
            advTags = new[] { "Cats", "Behaviour modification", "Senior cats", "Multi-pet households", "Anxious breeds", "Indoor cats" };
            advEmail = "marc.tremblay@pawdopt.ca"; advPhone = "+1 (416) 555-0192";
            break;
        case "aisha-johnson":
            advName = "Aisha Johnson"; advInitials = "AJ";
            advRole = "Family Transitions Advisor"; advLocation = "Vancouver, BC"; advStat = "87";
            advAvatarCss = "background:linear-gradient(135deg,#7c3aed,#5b21b6)";
            advBio = "Aisha specialises in supporting families going through major life transitions: relocation, divorce, a new baby, or health challenges. She brings a compassionate, judgment-free approach to a process that can feel emotionally overwhelming.\n\nHer goal is to help you make peace with your decision and find a genuinely great match for your pet, not just the fastest option available.";
            advTags = new[] { "Family transitions", "Relocation", "Divorce support", "New baby", "Dogs & cats", "Emotional support" };
            advEmail = "aisha.johnson@pawdopt.ca"; advPhone = "+1 (604) 555-0347";
            break;
        case "carlos-rivera":
            advName = "Carlos Rivera"; advInitials = "CR";
            advRole = "Emergency Rehoming"; advLocation = "Calgary, AB"; advStat = "65";
            advAvatarCss = "background:linear-gradient(135deg,#d97706,#b45309)";
            advBio = "Carlos focuses on urgent rehoming situations: when time is short and the stakes are high. Whether it's an unexpected eviction, a sudden illness, or an emergency trip abroad, he helps you act quickly without compromising the quality of the match.\n\nAvailable 7 days a week, Carlos builds fast but thorough screening processes so your pet ends up in safe, caring hands, even under serious time pressure.";
            advTags = new[] { "Emergency rehoming", "Urgent timelines", "Eviction support", "Illness", "All pet types", "7-day availability" };
            advEmail = "carlos.rivera@pawdopt.ca"; advPhone = "+1 (403) 555-0218";
            break;
        default: // sophie-martin
            advName = "Sophie Martin"; advInitials = "SM";
            advRole = "Dog Rehoming Specialist"; advLocation = "Montréal, QC"; advStat = "124";
            advAvatarCss = "background:linear-gradient(135deg,#1D8FA3,#176d7e)";
            advBio = "Sophie has helped over 120 dogs find loving homes across Québec and Ontario. Her work centres on high-energy breeds, dogs with behavioural challenges, and helping owners feel genuinely at peace with their rehoming decision.\n\nShe believes every dog deserves a family that understands their needs, and every owner deserves to move forward without guilt. Sophie guides you through the full process, from writing the perfect listing to screening and selecting the right adopter.";
            advTags = new[] { "Dogs", "High-energy breeds", "Behaviour challenges", "Senior dogs", "Listing advice", "Québec & Ontario" };
            advEmail = "sophie.martin@pawdopt.ca"; advPhone = "+1 (514) 555-0174";
            break;
    }

    var firstName = advName.Split(' ')[0];
    ViewData["Title"] = advName + " | Pawdopt Advisor";
}

<div class="radv-page">

    <!-- ── Profile hero ──────────────────────────────────────────── -->
    <div class="radv-hero">
        <div class="adopt-pg-container radv-hero-container">
            <a href="/Rehome/List#rl-advisors" class="radv-back-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                Back to all advisors
            </a>
            <div class="radv-hero-card">
                <div class="radv-avatar-xl" style="@advAvatarCss">@advInitials</div>
                <div class="radv-hero-info">
                    <h1 class="radv-name">@advName</h1>
                    <p class="radv-role-chip">@advRole</p>
                    <p class="radv-loc">📍 @advLocation</p>
                    <span class="radv-stat-pill">🐾 <strong>@advStat</strong> pets helped</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Body ──────────────────────────────────────────────────── -->
    <div class="adopt-pg-container">
        <div class="radv-body">
            <div class="radv-grid">

                <!-- Left: About + Specialties -->
                <div>
                    <div class="radv-section">
                        <p class="radv-sec-label">About</p>
                        <p class="radv-bio">@advBio</p>
                    </div>
                    <div class="radv-section">
                        <p class="radv-sec-label">Specialties</p>
                        <div class="radv-tags">
                            @foreach (var tag in advTags) {
                                <span class="radv-tag">@tag</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Right: Contact card -->
                <div>
                    <div class="radv-contact-card">
                        <p class="radv-contact-title">Get in touch with @firstName</p>
                        <p class="radv-contact-sub">Typically replies within 2–4 hours</p>

                        <a href="mailto:@advEmail" class="radv-cta-btn primary">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
                            <span>Email @firstName</span>
                        </a>
                        <a href="tel:@advPhone" class="radv-cta-btn outline">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                            <span>@advPhone</span>
                        </a>
                        <a href="#" class="radv-cta-btn outline" onclick="return false;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            <span>WhatsApp</span>
                        </a>
                        <a href="#" class="radv-cta-btn outline" onclick="return false;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            <span>Book a session</span>
                        </a>

                        <div class="radv-divider"></div>
                        <div class="radv-avail">
                            <span class="radv-avail-dot"></span>
                            Available this week · Free consultation
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>
