@{
    ViewData["Title"] = "Rehome a Pet";
}

<!-- ── Hero ─────────────────────────────────────────────── -->
<div class="rl-hero">
    <div class="adopt-pg-container">
        <div class="rl-hero-owner">
            <div class="rl-hero-text">
                <p class="rl-hero-eyebrow" data-i18n="rl-eyebrow">🐾 FOR PET OWNERS</p>
                <h1 class="rl-hero-title" data-i18n="rl-title">Give your pet the home they deserve</h1>
                <p class="rl-hero-sub" data-i18n="rl-subtitle">List your pet for free and connect directly with caring adopters in your area, in minutes.</p>
                <div class="rl-hero-actions">
                    <a href="/Rehome/NewListing" class="rl-btn-list" data-i18n="rl-btn-list">Start listing →</a>
                    <a href="#rl-advisors" class="rl-btn-ghost" data-i18n="rl-btn-advisors">Talk to an advisor ↓</a>
                </div>
            </div>
            <div class="rl-hero-metrics" aria-hidden="true">
                <div class="rl-metric">
                    <span class="rl-metric-num">48</span>
                    <span class="rl-metric-label" data-i18n="rl-metric1">rehomed this month</span>
                </div>
                <div class="rl-metric-sep"></div>
                <div class="rl-metric">
                    <span class="rl-metric-num">5 min</span>
                    <span class="rl-metric-label" data-i18n="rl-metric2">to create a listing</span>
                </div>
                <div class="rl-metric-sep"></div>
                <div class="rl-metric">
                    <span class="rl-metric-num">Free</span>
                    <span class="rl-metric-label" data-i18n="rl-metric3">always &amp; forever</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── How it works ──────────────────────────────────────── -->
<section class="rl-how">
    <div class="adopt-pg-container">
        <div class="rl-sec-head">
            <h2 class="rl-sec-title" data-i18n="rl-how-title">How rehoming works</h2>
            <p class="rl-sec-sub" data-i18n="rl-how-sub">Three simple steps to finding your pet a loving new home</p>
        </div>
        <div class="rl-how-paw-strip" aria-hidden="true">🐾 🐾 🐾 🐾 🐾 🐾 🐾 🐾 🐾 🐾</div>
        <div class="rl-how-steps">
            <div class="rl-how-step">
                <div class="rl-how-bubble">📝</div>
                <h3 class="rl-how-step-title" data-i18n="rl-how-s1">Create your listing</h3>
                <p class="rl-how-step-desc" data-i18n="rl-how-s1d">Fill out a short profile about your pet: personality, health, photos, and the kind of home you're hoping for.</p>
            </div>
            <div class="rl-how-arrow-paw" aria-hidden="true">🐾</div>
            <div class="rl-how-step">
                <div class="rl-how-bubble">🤝</div>
                <h3 class="rl-how-step-title" data-i18n="rl-how-s2">Get connected</h3>
                <p class="rl-how-step-desc" data-i18n="rl-how-s2d">Verified adopters near you discover your listing and reach out. You choose who to respond to, and you're always in control.</p>
            </div>
            <div class="rl-how-arrow-paw" aria-hidden="true">🐾</div>
            <div class="rl-how-step">
                <div class="rl-how-bubble">🏠</div>
                <h3 class="rl-how-step-title" data-i18n="rl-how-s3">Find the right match</h3>
                <p class="rl-how-step-desc" data-i18n="rl-how-s3d">Meet potential adopters, ask questions, and when it feels right, hand your pet to their new family with confidence.</p>
            </div>
        </div>
    </div>
</section>

<!-- ── Rehoming Advisors ──────────────────────────────────── -->
<section class="rl-advisors" id="rl-advisors">
    <div class="adopt-pg-container">
        <div class="rl-sec-head">
            <h2 class="rl-sec-title" data-i18n="rl-adv-title">Meet our rehoming advisors</h2>
            <p class="rl-sec-sub" data-i18n="rl-adv-sub">Not sure where to start? Our specialists are here to guide you: free, confidential, and judgment-free.</p>
        </div>
        <div class="rl-adv-grid">

            <div class="rl-adv-card">
                <div class="rl-adv-avatar" style="background:linear-gradient(135deg,#1D8FA3,#176d7e)">SM</div>
                <div class="rl-adv-body">
                    <div class="rl-adv-info">
                        <h3 class="rl-adv-name">Sophie Martin</h3>
                        <p class="rl-adv-role" data-i18n="rl-adv-r1">Dog Rehoming Specialist</p>
                        <p class="rl-adv-location">📍 Montréal, QC</p>
                        <p class="rl-adv-desc" data-i18n="rl-adv-d1">Helped 120+ dogs find loving homes. Expert in high-energy breeds, behavioural challenges, and helping owners feel at peace with their decision.</p>
                    </div>
                    <div class="rl-adv-footer">
                        <span class="rl-adv-stat">🐾 <strong>124</strong> <span data-i18n="rl-adv-stat-label">pets helped</span></span>
                        <a href="/Rehome/Advisor/sophie-martin" class="rl-adv-btn" data-i18n="rl-adv-btn">Get advice →</a>
                    </div>
                </div>
            </div>

            <div class="rl-adv-card">
                <div class="rl-adv-avatar" style="background:linear-gradient(135deg,#2d7dd2,#1a5fa8)">MT</div>
                <div class="rl-adv-body">
                    <div class="rl-adv-info">
                        <h3 class="rl-adv-name">Marc Tremblay</h3>
                        <p class="rl-adv-role" data-i18n="rl-adv-r2">Cat Behaviour Expert</p>
                        <p class="rl-adv-location">📍 Toronto, ON</p>
                        <p class="rl-adv-desc" data-i18n="rl-adv-d2">15+ years working with cats. Specialises in multi-pet households, senior cats, and shy or anxious breeds that need extra patience.</p>
                    </div>
                    <div class="rl-adv-footer">
                        <span class="rl-adv-stat">🐾 <strong>98</strong> <span data-i18n="rl-adv-stat-label">pets helped</span></span>
                        <a href="/Rehome/Advisor/marc-tremblay" class="rl-adv-btn" data-i18n="rl-adv-btn">Get advice →</a>
                    </div>
                </div>
            </div>

            <div class="rl-adv-card">
                <div class="rl-adv-avatar" style="background:linear-gradient(135deg,#7c3aed,#5b21b6)">AJ</div>
                <div class="rl-adv-body">
                    <div class="rl-adv-info">
                        <h3 class="rl-adv-name">Aisha Johnson</h3>
                        <p class="rl-adv-role" data-i18n="rl-adv-r3">Family Transitions Advisor</p>
                        <p class="rl-adv-location">📍 Vancouver, BC</p>
                        <p class="rl-adv-desc" data-i18n="rl-adv-d3">Supports families going through major life changes: relocation, divorce, or health issues, with compassionate and non-judgmental guidance.</p>
                    </div>
                    <div class="rl-adv-footer">
                        <span class="rl-adv-stat">🐾 <strong>87</strong> <span data-i18n="rl-adv-stat-label">pets helped</span></span>
                        <a href="/Rehome/Advisor/aisha-johnson" class="rl-adv-btn" data-i18n="rl-adv-btn">Get advice →</a>
                    </div>
                </div>
            </div>

            <div class="rl-adv-card">
                <div class="rl-adv-avatar" style="background:linear-gradient(135deg,#d97706,#b45309)">CR</div>
                <div class="rl-adv-body">
                    <div class="rl-adv-info">
                        <h3 class="rl-adv-name">Carlos Rivera</h3>
                        <p class="rl-adv-role" data-i18n="rl-adv-r4">Emergency Rehoming</p>
                        <p class="rl-adv-location">📍 Calgary, AB</p>
                        <p class="rl-adv-desc" data-i18n="rl-adv-d4">Rapid support for urgent situations: eviction, sudden illness, or unexpected travel. Available 7 days a week to help you act quickly without rushing the right decision.</p>
                    </div>
                    <div class="rl-adv-footer">
                        <span class="rl-adv-stat">🐾 <strong>65</strong> <span data-i18n="rl-adv-stat-label">pets helped</span></span>
                        <a href="/Rehome/Advisor/carlos-rivera" class="rl-adv-btn" data-i18n="rl-adv-btn">Get advice →</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ── Why Pawdopt ────────────────────────────────────────── -->
<section class="rl-why">
    <div class="adopt-pg-container">
        <h2 class="rl-sec-title" style="text-align:center;margin-bottom:2rem" data-i18n="rl-why-title">Why rehome through Pawdopt?</h2>
        <div class="rl-why-grid">
            <div class="rl-why-card">
                <span class="rl-why-icon">🔒</span>
                <h4 class="rl-why-ctitle" data-i18n="rl-why-c1">Safe &amp; private</h4>
                <p class="rl-why-cdesc" data-i18n="rl-why-c1d">Your address is never shown publicly. Only your city and province appear on your listing.</p>
            </div>
            <div class="rl-why-card">
                <span class="rl-why-icon">💬</span>
                <h4 class="rl-why-ctitle" data-i18n="rl-why-c3">Direct contact</h4>
                <p class="rl-why-cdesc" data-i18n="rl-why-c3d">Talk to adopters before deciding. Read their profiles and ask as many questions as you need.</p>
            </div>
            <div class="rl-why-card">
                <span class="rl-why-icon">🐾</span>
                <h4 class="rl-why-ctitle" data-i18n="rl-why-c4">You stay in control</h4>
                <p class="rl-why-cdesc" data-i18n="rl-why-c4d">You choose who to meet. You decide the timing. You pick the family that feels right for your pet.</p>
            </div>
        </div>
    </div>
</section>

